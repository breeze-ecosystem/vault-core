generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  OPERATOR
  VIEWER
  AUDITOR
  MAINTENANCE_TEAM
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum CredentialType {
  BADGE
  PIN
  MOBILE
  QR
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum CameraStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  DEGRADED
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  FALSE_POSITIVE
}

enum NotificationChannel {
  EMAIL
  WEBHOOK
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum LicenseStatus {
  PENDING
  ACTIVE
  GRACE
  EXPIRED
}

// ─── Phase 1: Access Control Reference Tables ───

model Credential {
  id             String         @id @default(uuid())
  userId         String
  type           CredentialType
  badgeNumber    String?        @unique
  pinHash        String?
  mobileWalletId String?
  qrSeed         String?
  isActive       Boolean        @default(true)
  validFrom      DateTime?
  validUntil     DateTime?
  maxUses        Int?
  useCount       Int            @default(0)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id])
  accessLevels    AccessLevel[]
  visits          Visit[]

  @@index([userId])
  @@index([type, badgeNumber])
  @@index([organizationId])
}

model Door {
  id           String   @id @default(uuid())
  name         String
  organizationId String
  zoneId       String
  location     String?
  controllerId String?
  alertConfig  Json     @default("{}")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  zone         Zone           @relation(fields: [zoneId], references: [id])
  cameraMaps   CameraDoorMap[]

  @@index([organizationId])
  @@index([zoneId])
  @@unique([controllerId, organizationId])
}

model Zone {
  id          String   @id @default(uuid())
  name        String
  organizationId String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  doors        Door[]
  schedules    Schedule[]
  accessLevels AccessLevel[]

  @@index([organizationId])
}

model Schedule {
  id              String   @id @default(uuid())
  name            String
  zoneId          String
  entries         Json
  holidayOverride String?  @default("none")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  zone         Zone          @relation(fields: [zoneId], references: [id])
  accessLevels AccessLevel[]

  @@index([zoneId])
}

model AccessLevel {
  id           String   @id @default(uuid())
  credentialId String
  zoneId       String
  scheduleId   String
  priority     Int      @default(0)
  createdAt    DateTime @default(now())

  credential Credential @relation(fields: [credentialId], references: [id])
  zone       Zone       @relation(fields: [zoneId], references: [id])
  schedule   Schedule   @relation(fields: [scheduleId], references: [id])

  @@unique([credentialId, zoneId, scheduleId])
  @@index([credentialId])
  @@index([zoneId])
}

model CameraDoorMap {
  id       String  @id @default(uuid())
  cameraId String
  doorId   String
  angle    String?
  priority Int     @default(0)

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  door   Door   @relation(fields: [doorId], references: [id], onDelete: Cascade)

  @@unique([cameraId, doorId])
  @@index([doorId])
}

// ─── Phase 2: Incident Management Models ───

model Incident {
  id              String   @id @default(uuid())
  title           String
  description     String?
  severity        AlertSeverity
  status          String   @default("OPEN")
  organizationId  String
  sourceType      String?
  sourceId        String?
  assignedToId    String?
  assignedAt      DateTime?

  // Maintenance ticket fields (WFL-01):
  ticketType         String?  @default("SECURITY_INCIDENT")  // 'SECURITY_INCIDENT' | 'MAINTENANCE_TICKET'
  deviceId           String?  // FK to camera/reader/controller
  deviceType         String?  // 'camera' | 'reader' | 'controller'
  deviceName         String?  // Denormalized for quick display

  escalationChain Json     @default("[]")
  slaMinutes      Int      @default(30)
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization          @relation(fields: [organizationId], references: [id])
  assignedTo      User?                 @relation("IncidentAssignee", fields: [assignedToId], references: [id])
  alert           Alert?                @relation(fields: [sourceId], references: [id])
  comments        IncidentComment[]
  assignments     IncidentAssignment[]
  escalations     IncidentEscalation[]
  evidence        IncidentEvidence[]

  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([status])
  @@index([ticketType])
  @@index([deviceType, deviceId])
}

model IncidentComment {
  id         String   @id @default(uuid())
  incidentId String
  userId     String
  text       String
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([incidentId])
}

model IncidentAssignment {
  id           String   @id @default(uuid())
  incidentId   String
  assignedById String
  assignedToId String
  assignedAt   DateTime @default(now())
  note         String?

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  assignedBy User     @relation("AssignmentBy", fields: [assignedById], references: [id])
  assignedTo User     @relation("AssignmentTo", fields: [assignedToId], references: [id])

  @@index([incidentId])
}

model IncidentEscalation {
  id           String    @id @default(uuid())
  incidentId   String
  level        Int       @default(1)
  notifyUserId String?
  slaMinutes   Int
  notifiedAt   DateTime?
  resolvedAt   DateTime?

  incident  Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  notifyUser User?    @relation(fields: [notifyUserId], references: [id])

  @@index([incidentId])
}

// ─── Incident Evidence Model ───

model IncidentEvidence {
  id           String   @id @default(uuid())
  incidentId   String
  type         String   // 'video_clip', 'snapshot', 'access_event', 'document', 'note'
  url          String?  // URL to video clip, snapshot image, or document
  eventType    String?  // 'access_granted', 'door_forced', 'tailgating', etc.
  eventId      String?  // ID of the referenced event in TimescaleDB hypertable
  description  String?
  uploadedById String
  createdAt    DateTime @default(now())

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@index([incidentId])
}

// ─── Phase 2: Visitor Management Models ───

model Visitor {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  company   String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits Visit[]

  @@index([email])
  @@index([lastName, firstName])
}

model Visit {
  id              String    @id @default(uuid())
  visitorId       String
  hostUserId      String
  purpose         String?
  validFrom       DateTime
  validUntil      DateTime
  credentialId    String
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  status          String    @default("scheduled")
  zoneRestrictions Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  visitor    Visitor    @relation(fields: [visitorId], references: [id])
  host       User       @relation("VisitHost", fields: [hostUserId], references: [id])
  credential Credential @relation(fields: [credentialId], references: [id])

  @@index([visitorId])
  @@index([hostUserId])
  @@index([status])
  @@index([credentialId])
}

// ─── ANPR/Vehicle Models ───

model VehicleList {
  id          String   @id @default(uuid())
  type        String   // 'allowlist' or 'blocklist'
  plate       String
  organizationId String
  description String?
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    User         @relation(fields: [createdById], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([type, plate, organizationId])
  @@index([type, organizationId])
  @@index([plate])
}

// ─── Phase 2: Equipment Health & Governance Models ───

model RetentionPolicy {
  id            String   @id @default(uuid())
  eventType     String   @unique
  tableType     String   // 'timescaledb' or 'prisma'
  retentionDays Int
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([eventType])
  @@index([enabled])
}

// ─── Organization Model (renamed from Site) ───

model Organization {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  country   String   @default("SN")
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  stripeCustomerId String?
  billingEmail     String?
  planTier         String?  // 'FREE' | 'PROFESSIONAL' | 'ENTERPRISE'
  trialStartDate   DateTime?
  trialEndDate     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cameras           Camera[]
  doors             Door[]
  zones             Zone[]
  incidents         Incident[]
  members           OrganizationMember[]
  invites           Invite[]
  auditLogs         AuditLog[]
  vehicleListEntries VehicleList[]
  featureFlags      FeatureFlag[]
  credentials       Credential[]
  alerts            Alert[]
  cameraPrompts     CameraPrompt[]
  licenses          License[]
  apiKeys           LicenseApiKey[]
}

model Camera {
  id              String       @id @default(uuid())
  name            String
  rtspUrl         String
  status          CameraStatus @default(OFFLINE)
  organizationId  String
  resolution      String?
  fps             Int          @default(25)
  captureInterval Int          @default(5)
  isRecording     Boolean      @default(false)
  lastSnapshotUrl String?
  lastHeartbeat   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  alerts       Alert[]
  prompts      CameraPrompt[]
  cameraDoorMaps CameraDoorMap[]

  @@index([organizationId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships              OrganizationMember[]
  credentials              Credential[]
  refreshTokens            RefreshToken[]
  pushTokens               MobilePushToken[]
  auditLogs                AuditLog[]
  notificationSettings     NotificationSetting[]
  assignedIncidents        Incident[]             @relation("IncidentAssignee")
  incidentComments         IncidentComment[]
  incidentAssignmentsBy    IncidentAssignment[]    @relation("AssignmentBy")
  incidentAssignmentsTo    IncidentAssignment[]    @relation("AssignmentTo")
  incidentEscalations      IncidentEscalation[]
  uploadedEvidence         IncidentEvidence[]
  hostedVisits             Visit[]                @relation("VisitHost")
  vehicleListEntries       VehicleList[]
  createdInvites           Invite[]               @relation("InviteCreator")
  acceptedInvites          Invite[]               @relation("InviteAcceptor")
  licenseApiKeys           LicenseApiKey[]
}

// ─── Multi-Tenancy: Organization Member Join Table ───

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           Role
  isActive       Boolean  @default(true)
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

// ─── Multi-Tenancy: Invite Token Tracking ───

model Invite {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           Role
  token          String       @unique
  status         String       @default("PENDING")  // PENDING, ACCEPTED, EXPIRED, REVOKED
  createdById    String
  acceptedById   String?
  acceptedAt     DateTime?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("InviteCreator", fields: [createdById], references: [id])
  acceptedBy   User?        @relation("InviteAcceptor", fields: [acceptedById], references: [id])

  @@index([organizationId])
  @@index([email, organizationId])
}

// ─── Multi-Tenancy: Feature Flags ───

model FeatureFlag {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  enabled        Boolean  @default(false)
  tier           String?  // minimum tier: 'FREE', 'PROFESSIONAL', 'ENTERPRISE'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId])
}

// ─── Alert Model ───

model Alert {
  id             String        @id @default(uuid())
  title          String
  description    String?
  severity       AlertSeverity
  status         AlertStatus   @default(OPEN)
  cameraId       String
  organizationId String
  snapshotUrl    String?
  metadata       Json?
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  camera            Camera             @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  organization      Organization       @relation(fields: [organizationId], references: [id])
  notificationLogs  NotificationLog[]
  incidents         Incident[]

  @@index([organizationId])
}

model CameraPrompt {
  id        String        @id @default(uuid())
  cameraId  String
  text      String
  severity  AlertSeverity @default(MEDIUM)
  isActive  Boolean       @default(true)
  organizationId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  camera       Camera       @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MobilePushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  changes     Json?
  ipAddress   String?
  userAgent   String?
  organizationId String?
  previousHash   String?
  currentHash    String?
  content        String?
  createdAt   DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([organizationId])
  @@index([createdAt])
}

model NotificationTemplate {
  id              String             @id @default(uuid())
  name            String             @unique
  channel         NotificationChannel
  subjectTemplate String?
  bodyTemplate    String
  createdAt       DateTime           @default(now())
}

model NotificationLog {
  id        String             @id @default(uuid())
  alertId   String
  channel   NotificationChannel
  recipient String
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?
  error     String?
  createdAt DateTime           @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([recipient])
  @@index([status])
}

model NotificationSetting {
  id        String             @id @default(uuid())
  userId    String
  channel   NotificationChannel
  enabled   Boolean            @default(true)
  config    Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
}

// ─── Phase 5: License Management Models ───

model License {
  id             String        @id @default(uuid())
  organizationId String
  licenseJwt     String
  status         LicenseStatus @default(PENDING)
  activatedAt    DateTime?
  expiresAt      DateTime
  maxCameras     Int
  maxDoors       Int
  gracePeriodDays Int          @default(7)
  licenseVersion  Int          @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@unique([organizationId, licenseVersion])
}

model LicenseApiKey {
  id             String    @id @default(uuid())
  name           String
  keyHash        String    @unique
  keyPrefix      String
  isActive       Boolean   @default(true)
  organizationId String
  createdById    String
  createdAt      DateTime  @default(now())
  revokedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([isActive])
  @@index([keyHash])
}
