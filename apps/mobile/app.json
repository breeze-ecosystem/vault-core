{
  "expo": {
    "name": "OVERSIGHT AI",
    "slug": "oversight-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "oversight",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0a0a0a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oversight.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "Cette application utilise la caméra pour la capture d'écran de surveillance.",
        "NSMicrophoneUsageDescription": "Cette application utilise le microphone pour les flux audio des caméras."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.oversight.ai",
      "permissions": ["INTERNET", "CAMERA", "RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Cette application utilise le microphone pour les flux audio des caméras."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "oversight-ai"
      }
    }
  }
}
