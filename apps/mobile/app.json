{
  "expo": {
    "name": "OVERSIGHT AI",
    "slug": "oversight-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "oversight",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0a0a0a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oversight.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "Cette application utilise la caméra pour la capture d'écran de surveillance.",
        "NSMicrophoneUsageDescription": "Cette application utilise le microphone pour les flux audio des caméras."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.oversight.ai",
      "permissions": [
        "INTERNET",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Cette application utilise le microphone pour les flux audio des caméras."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab677ee6-a3d8-46f5-a1a3-bf212bd69217"
      },
      "apiUrl": "https://oversight-api.digitsoftafrica.com/api",
      "streamUrl": "https://oversight-stream.digitsoftafrica.com"
    },
    "owner": "jmasto"
  }
}
