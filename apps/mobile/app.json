{
  "expo": {
    "name": "OVERSIGHT AI",
    "slug": "oversight-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "oversight",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oversight.ai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.oversight.ai"
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
