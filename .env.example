# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         OVERSIGHT AI — Configuration                        ║
# ║               Système de surveillance vidéo intelligent                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
#
# Ce fichier est un modèle (.env.example).
# Pour configurer votre installation :
#   1. Copiez ce fichier vers .env :  cp .env.example .env
#   2. Remplacez toutes les valeurs CHANGE_ME_* par vos propres valeurs
#   3. Les variables marquées [REQUIS] doivent obligatoirement être renseignées
#   4. Les variables marquées [OPTIONNEL] ont une valeur par défaut raisonnable
#
# ATTENTION : Ne jamais committer le fichier .env dans le dépôt Git.
#             Ce fichier .env.example est le seul qui doit être versionné.
#
# ──────────────────────────────────────────────────────────────────────────────


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        VARIABLES PARTAGÉES (COMMUNES)                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Environnement d'exécution — development | production | test
# [OPTIONNEL] Défaut : development
NODE_ENV=production

# Nom de l'entreprise cliente (affiché dans l'interface et les rapports)
# [OPTIONNEL] Défaut : OVERSIGHT AI
COMPANY_NAME=CHANGE_ME_COMPANY_NAME

# Nom de l'application affiché dans le tableau de bord
# [OPTIONNEL] Défaut : OVERSIGHT AI
NEXT_PUBLIC_APP_NAME=CHANGE_ME_APP_NAME


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                           BASE DE DONNÉES (PostgreSQL)                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL de connexion PostgreSQL complète
# Format : postgresql://<utilisateur>:<mot_de_passe>@<hote>:<port>/<base>
# [REQUIS]
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/oversight


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                               CACHE (Redis)                                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Hôte du serveur Redis
# [OPTIONNEL] Défaut : localhost
REDIS_HOST=localhost

# Port du serveur Redis
# [OPTIONNEL] Défaut : 6379
REDIS_PORT=6379

# Mot de passe Redis (laisser vide si pas d'authentification)
# [OPTIONNEL] Défaut : (aucun)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                              API (NestJS)                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Port d'écoute de l'API
# [OPTIONNEL] Défaut : 4000
PORT=4000

# ── Authentification JWT ──────────────────────────────────────────────────────

# Clé secrète pour la signature des jetons d'accès (access tokens)
# [REQUIS] Utilisez une chaîne aléatoire de 64+ caractères en production
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET

# Clé secrète pour la signature des jetons de rafraîchissement (refresh tokens)
# [REQUIS] Utilisez une chaîne aléatoire de 64+ caractères en production
#          Doit être DIFFÉRENTE de JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET

# Durée de validité des jetons d'accès
# [OPTIONNEL] Défaut : 15m (15 minutes). Formats : 60s, 15m, 1h, 1d
JWT_ACCESS_EXPIRY=15m

# Durée de validité des jetons de rafraîchissement
# [OPTIONNEL] Défaut : 7d (7 jours). Formats : 1h, 1d, 7d, 30d
JWT_REFRESH_EXPIRY=7d

# Clé secrète pour la signature des jetons d'invitation (invite tokens)
# [REQUIS pour l'invitation d'utilisateurs]
# Utilisez une chaîne aléatoire de 64+ caractères en production
JWT_INVITE_SECRET=change-me-invite-secret-in-prod

# ── CORS (Cross-Origin Resource Sharing) ──────────────────────────────────────

# Origines autorisées pour les requêtes cross-origin
# [OPTIONNEL] Défaut : * (toutes). En production, indiquez le domaine du dashboard.
# Exemple : https://oversight.example.com
CORS_ORIGIN=*

# Autoriser l'envoi de cookies/credentials dans les requêtes cross-origin
# [OPTIONNEL] Défaut : false. Valeurs possibles : true | false
CORS_CREDENTIALS=false

# ── Limitation de débit (Rate Limiting) ───────────────────────────────────────

# Fenêtre de temps pour le compteur de requêtes (en secondes)
# [OPTIONNEL] Défaut : 60
RATE_LIMIT_TTL=60

# Nombre maximum de requêtes autorisées par fenêtre de temps
# [OPTIONNEL] Défaut : 20
RATE_LIMIT_MAX=20


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                       TABLEAU DE BORD (Dashboard — Next.js)                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL publique de l'API (accessible depuis le navigateur client)
# [REQUIS] Exemple : https://oversight-api.example.com
NEXT_PUBLIC_API_URL=CHANGE_ME_API_PUBLIC_URL

# Port d'écoute du dashboard (utilisé par le serveur Next.js)
# [OPTIONNEL] Défaut : 3100
DASHBOARD_PORT=3100


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                     PRÉPROCESSEUR AI (AI Preprocessor — FastAPI)            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL interne du service AI Preprocessor (depuis l'API)
# [OPTIONNEL] Défaut : http://localhost:8000
# En Docker : http://ai-preprocessor:8000
AI_PREPROCESSOR_URL=http://localhost:8000


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                           IA / INFÉRENCE (Ollama)                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL du serveur Ollama (modèles LLM locaux)
# [OPTIONNEL] Défaut : http://localhost:11434
# En Docker : http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         BASE VECTORIELLE (Qdrant)                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL du serveur Qdrant (recherche vectorielle pour l'IA)
# [OPTIONNEL] Défaut : http://localhost:6333
QDRANT_URL=http://localhost:6333


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                     NOTIFICATIONS PUSH (FCM / Webhook)                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Clé serveur Firebase Cloud Messaging (FCM)
# [OPTIONNEL] Laisser vide pour désactiver les notifications push
FCM_SERVER_KEY=

# Chemin vers le fichier JSON d'identifiants Firebase (alternative à FCM_SERVER_KEY)
# [OPTIONNEL] Laisser vide si non utilisé
FIREBASE_CREDENTIALS=

# URL du webhook pour les notifications push (alternative à FCM)
# [OPTIONNEL] Laisser vide si non utilisé
PUSH_WEBHOOK_URL=


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                   NOTIFICATIONS — Email (SMTP) & Contrôle global            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Hôte du serveur SMTP pour les notifications par e-mail
# [OPTIONNEL] Laisser vide pour désactiver les e-mails
SMTP_HOST=

# Port du serveur SMTP (587 = TLS, 465 = SSL, 25 = non chiffré)
# [OPTIONNEL] Défaut : 587
SMTP_PORT=587

# Nom d'utilisateur SMTP
# [OPTIONNEL]
SMTP_USER=

# Mot de passe SMTP
# [OPTIONNEL]
SMTP_PASS=

# Adresse expéditeur pour les e-mails de notification
# [OPTIONNEL] Défaut : no-reply@oversight.local
SMTP_FROM=no-reply@oversight.local

# Activer/désactiver le système de notifications (e-mail, webhook, in-app)
# [OPTIONNEL] Défaut : true
NOTIFICATION_ENABLED=true


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    INITIALISATION (Seed — Première installation)            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
# Ces variables sont utilisées uniquement lors de la première initialisation
# de la base de données (seed). Elles créent le compte administrateur initial.
# Vous pouvez les supprimer du .env après le premier seed.

# Adresse e-mail du compte administrateur
# [REQUIS pour le seed]
ADMIN_EMAIL=admin@CHANGE_ME_DOMAIN

# Mot de passe du compte administrateur (minimum 8 caractères)
# [REQUIS pour le seed]
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Prénom de l'administrateur
# [REQUIS pour le seed]
ADMIN_FIRST_NAME=Admin

# Nom de famille de l'administrateur
# [REQUIS pour le seed]
ADMIN_LAST_NAME=CHANGE_ME_LAST_NAME


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    STREAMING VIDÉO (go2rtc)                                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL du serveur go2rtc pour le streaming live (WebRTC/HLS)
# [OPTIONNEL] Défaut : http://localhost:1984
# En production edge : http://go2rtc:1984
NEXT_PUBLIC_STREAM_URL=http://localhost:1984


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    NOTIFICATIONS — Resend (Email API)                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Clé API Resend pour les alertes par email
# [REQUIS] Obtenez votre clé sur https://resend.com
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY

# Adresse expéditeur pour les emails Resend
# [OPTIONNEL] Défaut : onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                               MQTT (Mosquitto)                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL du broker MQTT (Mosquitto)
# [OPTIONNEL] Défaut : mqtt://localhost:1883
MQTT_BROKER_URL=mqtt://localhost:1883

# Nom d'utilisateur broker MQTT (laisser vide si pas d'authentification)
# [OPTIONNEL]
MQTT_USERNAME=

# Mot de passe broker MQTT (laisser vide si pas d'authentification)
# [OPTIONNEL]
MQTT_PASSWORD=


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         DATA GOVERNANCE                                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Clé de chiffrement pgcrypto pour le chiffrement au repos des données sensibles
# (informations visiteurs, numéros de badge, données PII)
# [REQUIS] Utilisez une chaîne aléatoire de 32+ bytes. Exemple : openssl rand -hex 32
ENCRYPTION_KEY=change-me-to-a-random-32-byte-key


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    SUPERVISION EDGE (Console DigitSoft)                     ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Clé secrète pour l'authentification des edge agents
# [REQUIS pour le mode edge] Les agents l'utilisent pour s'authentifier
EDGE_AGENT_SECRET=CHANGE_ME_EDGE_AGENT_SECRET

# URL de la console de supervision (pour les edge agents)
# [OPTIONNEL] Défaut : http://localhost:4000/api/edge
SUPERVISION_API_URL=http://localhost:4000/api/edge


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    LICENCES (Licence signing key)                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Chemin vers la clé privée RSA (fichier PEM) pour la signature des licences JWT
# [OPTIONNEL] Si non défini, la génération de licences est désactivée
LICENSE_PRIVATE_KEY_PATH=/app/secrets/license-private.pem

# Version du format de licence (incrémenter lors d'un changement de format)
# [OPTIONNEL] Défaut : 1
LICENSE_VERSION=1
