# ──────────────────────────────────────────────
# Oversight Hub — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── PostgreSQL ──
POSTGRES_USER=oversight
POSTGRES_PASSWORD=oversight_dev
POSTGRES_DB=oversight
POSTGRES_PORT=5435
DATABASE_URL=postgresql://oversight:oversight_dev@localhost:5435/oversight

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# ── Ollama (runs on host machine) ──
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── AI Preprocessor ──
AI_PREPROCESSOR_URL=http://ai-preprocessor:8000
AI_PREPROCESSOR_PORT=8000

# ── API (NestJS) ──
API_PORT=4000
NODE_ENV=production

# ── Dashboard (Next.js) ──
DASHBOARD_PORT=3100
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── JWT Authentication ──
JWT_ACCESS_SECRET=change-me-access-secret-in-prod
JWT_REFRESH_SECRET=change-me-refresh-secret-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Caddy (Reverse Proxy) ──
HTTP_PORT=80
HTTPS_PORT=443
