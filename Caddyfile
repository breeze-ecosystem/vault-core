oversighthub.com {
	# Marketing site
	handle {
		reverse_proxy marketing:3200
	}

	log {
		output stdout
	}
}

app.oversighthub.com {
	# API routes
	handle /api/* {
		reverse_proxy api:4000
	}

	# WebSocket routes
	handle /ws/* {
		reverse_proxy api:4000
	}

	# Dashboard (everything else)
	handle {
		reverse_proxy dashboard:3100
	}

	log {
		output stdout
	}
}
